{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "MCP_TIMEOUT": "30000",
    "MCP_TOOL_TIMEOUT": "180000"
  },
  "permissions": {
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/gws-write-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__brave-search__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/brave-fallback-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-commit-push.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "mcpServers": {},
  "enabledPlugins": {
    "dbt-skills@data-engineering-skills": true,
    "snowflake-skills@data-engineering-skills": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "max",
  "showTurnDuration": true,
  "teammateMode": "tmux"
}
